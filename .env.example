NODE_ENV=production
PORT=8080
PUBLIC_BASE_URL=https://bot.example.com
AERO_API_BASE_URL=https://api.aeromessenger.example
AERO_CLIENT_ID=replace-me
AERO_CLIENT_SECRET=replace-me
JWT_SECRET=replace-with-strong-secret
TOKEN_ENCRYPTION_KEY=32-byte-base64-key
DATABASE_URL=postgres://aero:aero@postgres:5432/aero_group_guard
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=aerogroupguard-assets
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
ELASTICSEARCH_URL=http://elasticsearch:9200
BULLMQ_PREFIX=aerogroupguard
PROMETHEUS_ENABLED=true
OPENAI_API_KEY=replace-me
AI_MODEL=gpt-4.1-mini
LOCAL_LLM_URL=http://localhost:11434
LOG_LEVEL=info
RATE_LIMIT_PER_MINUTE=120

# Aero Messenger Bot Credentials (Persistent AutoConnect)
AERO_EMAIL=your-email@example.com
AERO_PASSWORD=your-password
AERO_COOKIE=

